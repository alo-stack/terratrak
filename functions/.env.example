# Local Development Environment Variables
# Copy this to .env when testing locally (DO NOT COMMIT .env to git)

# Gmail Configuration
GMAIL_EMAIL=your-email@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

# Security Configuration
SETTINGS_PASSWORD=replace-with-strong-settings-password
TEST_EMAIL_TOKEN=replace-with-long-random-token

# For production, use Firebase environment config instead:
# firebase functions:config:set gmail.email="your@gmail.com"
# firebase functions:config:set gmail.password="your-app-password"
# firebase functions:config:set notification.recipient="alerts@email.com"
